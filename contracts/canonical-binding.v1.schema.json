{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harness.local/contracts/canonical-binding.v1.schema.json",
  "title": "Canonical binding registry receipt",
  "type": "object",
  "required": ["schema", "result", "receipt"],
  "additionalProperties": false,
  "properties": {
    "schema": {"const": "harness.runtime.canonical-binding.v1"},
    "result": {
      "type": "object",
      "required": ["project_slug", "canonical_cwd", "write_scope", "binding_revision", "source_ref"],
      "additionalProperties": false,
      "properties": {
        "project_slug": {"type": "string"},
        "canonical_cwd": {"type": "string"},
        "write_scope": {"type": "string"},
        "binding_revision": {"type": "string"},
        "source_ref": {"type": "string"}
      }
    },
    "receipt": {
      "type": "object",
      "required": ["resolver_revision", "binding_digest", "session_key", "consumer_readback"],
      "additionalProperties": false,
      "properties": {
        "resolver_revision": {"type": "string"},
        "binding_digest": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "session_key": {"type": "string"},
        "consumer_readback": {
          "type": "object",
          "required": ["platform", "guild_id", "parent_channel_id", "thread_id", "profile"],
          "additionalProperties": false,
          "properties": {
            "platform": {"type": "string"},
            "guild_id": {"type": "string"},
            "parent_channel_id": {"type": "string"},
            "thread_id": {"type": "string"},
            "profile": {"type": "string"}
          }
        }
      }
    }
  }
}

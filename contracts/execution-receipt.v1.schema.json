{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harness.local/contracts/execution-receipt.v1.schema.json",
  "title": "Harness isolated runtime execution receipt",
  "type": "object",
  "required": ["schema", "sequence", "event", "status", "case_id", "consumer", "recorded_at", "exit_code", "artifacts"],
  "properties": {
    "schema": {"const": "harness.runtime.execution-receipt.v1"},
    "sequence": {"type": "integer", "minimum": 1},
    "event": {"enum": ["dispatch", "terminal"]},
    "status": {"enum": ["observed", "pass", "fail"]},
    "case_id": {"type": "string", "minLength": 1},
    "consumer": {"type": "string", "minLength": 1},
    "recorded_at": {"type": "string", "format": "date-time"},
    "exit_code": {"type": ["integer", "null"]},
    "artifacts": {
      "type": "object",
      "required": ["body", "stdout", "stderr"],
      "additionalProperties": false,
      "properties": {
        "body": {"$ref": "#/$defs/artifact"},
        "stdout": {"$ref": "#/$defs/artifact"},
        "stderr": {"$ref": "#/$defs/artifact"}
      }
    },
    "execution": {
      "type": "object",
      "required": ["argv", "argv_sha256", "environment", "environment_sha256", "git_commit", "git_tree", "worktree_cwd", "worktree_cwd_sha256"],
      "additionalProperties": false,
      "properties": {
        "argv": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "argv_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "environment": {
          "type": "object",
          "required": ["HARNESS_STATE_DIR", "LANG", "LC_ALL", "PATH", "TZ"],
          "additionalProperties": false,
          "properties": {
            "HARNESS_STATE_DIR": {"type": "string", "minLength": 1},
            "LANG": {"const": "C"},
            "LC_ALL": {"const": "C"},
            "PATH": {"type": "string"},
            "TZ": {"const": "UTC"}
          }
        },
        "environment_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "git_commit": {"type": "string", "pattern": "^[0-9a-f]{40,64}$"},
        "git_tree": {"type": "string", "pattern": "^[0-9a-f]{40,64}$"},
        "worktree_cwd": {"type": "string", "minLength": 1},
        "worktree_cwd_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    }
  },
  "allOf": [
    {
      "if": {"properties": {"event": {"const": "dispatch"}}},
      "then": {
        "properties": {
          "sequence": {"const": 1},
          "status": {"const": "observed"},
          "exit_code": {"const": null}
        },
        "not": {"required": ["execution"]}
      }
    },
    {
      "if": {"properties": {"event": {"const": "terminal"}}},
      "then": {
        "required": ["execution"],
        "properties": {
          "sequence": {"const": 2},
          "status": {"enum": ["pass", "fail"]},
          "exit_code": {"type": "integer"}
        }
      }
    },
    {
      "if": {"properties": {"status": {"const": "pass"}}},
      "then": {"properties": {"exit_code": {"const": 0}}}
    },
    {
      "if": {"properties": {"status": {"const": "fail"}}},
      "then": {"properties": {"exit_code": {"not": {"const": 0}}}}
    }
  ],
  "$defs": {
    "artifact": {
      "type": "object",
      "required": ["ref", "sha256", "bytes"],
      "additionalProperties": false,
      "properties": {
        "ref": {"type": "string", "pattern": "^artifacts/"},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "bytes": {"type": "integer", "minimum": 0}
      }
    }
  },
  "additionalProperties": false
}

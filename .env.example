# Harness CPS memory Supabase runtime env
# Copy to .env locally if this repo stops borrowing Ai-prompter runtime keys.
# Do not commit filled secret values.

HARNESS_MEMORY_SUPABASE_PROJECT_NAME=harness-learning
HARNESS_MEMORY_SUPABASE_PROJECT_REF=
HARNESS_MEMORY_SUPABASE_REGION=
HARNESS_MEMORY_SUPABASE_URL=
HARNESS_MEMORY_SUPABASE_SERVICE_ROLE_KEY=
HARNESS_MEMORY_SUPABASE_ANON_KEY=

# Optional for remote migration apply via Supabase CLI.
# Keep blank in git; set only in local/runtime env when needed.
SUPABASE_ACCESS_TOKEN=
SUPABASE_DB_PASSWORD=

# Optional: point scripts at a non-default env file.
